# Base URL of the RS School API. For local development point at your local
# NestJS instance, for production point at the deployed app.
# Examples:
#   http://localhost:3000          (local NestJS)
#   https://app.staging.rs.school  (staging)
#   https://app.rs.school          (production)
RSAPP_BASE_URL=http://localhost:3000

# Personal access token (PAT) created in RS School under Profile -> API tokens.
# Issued once, store securely, revoke if leaked. Must start with "rsapp_pat_".
RSAPP_PAT=rsapp_pat_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
